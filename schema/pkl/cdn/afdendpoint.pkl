module azure.cdn.afdendpoint

import "@formae/formae.pkl"
import "../azure.pkl"

const type = "AZURE::Cdn::AFDEndpoint"
const apiVersion = "2023-05-01"

open class AFDEndpointResolvable extends formae.Resolvable {
    hidden type = module.type

    hidden id: AFDEndpointResolvable = (this) {
        property = "id"
    }
    hidden name: AFDEndpointResolvable = (this) {
        property = "name"
    }
    /// Output-only: the endpoint host name, e.g. contoso-abc.z01.azurefd.net.
    hidden hostName: AFDEndpointResolvable = (this) {
        property = "hostName"
    }
}

@azure.ResourceHint {
    type = module.type
    identifier = "id"
    apiVersion = module.apiVersion
    parent = "AZURE::Cdn::Profile"
    listParam = List(
        new formae.ListProperty { parentProperty = "name" listParameter = "profileName" },
        new formae.ListProperty { parentProperty = "resourceGroupName" listParameter = "resourceGroupName" }
    )
}
open class AFDEndpoint extends formae.Resource {

    /// Endpoint name (unique within the profile).
    @azure.FieldHint { required = true; createOnly = true }
    name: String(length >= 1 && length <= 46)

    /// Always "global" for Azure Front Door endpoints.
    @azure.FieldHint { required = true; createOnly = true }
    location: azure.Location = "global"

    @azure.FieldHint { required = true; createOnly = true }
    resourceGroupName: String(length >= 1 && length <= 90)|formae.Resolvable

    /// Name of the Front Door profile that holds this endpoint.
    @azure.FieldHint { required = true; createOnly = true }
    profileName: String|formae.Resolvable

    /// Whether the endpoint is enabled. Permitted values are 'Enabled' or 'Disabled'.
    @azure.FieldHint {}
    enabledState: ("Enabled"|"Disabled") = "Enabled"

    /// Indicates the endpoint name reuse scope.
    @azure.FieldHint { createOnly = true }
    autoGeneratedDomainNameLabelScope: ("TenantReuse"|"SubscriptionReuse"|"ResourceGroupReuse"|"NoReuse")?

    @azure.FieldHint { outputField = "Tags"; updateMethod = "EntitySet"; indexField = "Key" }
    tags: Listing<azure.Tag>?

    hidden parent = this

    hidden res: AFDEndpointResolvable = new {
        label = parent.label
        stack = parent.stack?.label
    }
}
