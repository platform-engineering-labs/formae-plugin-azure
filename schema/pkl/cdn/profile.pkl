module azure.cdn.profile

import "@formae/formae.pkl"
import "../azure.pkl"

const type = "AZURE::Cdn::Profile"
const apiVersion = "2023-05-01"

open class ProfileResolvable extends formae.Resolvable {
    hidden type = module.type

    hidden id: ProfileResolvable = (this) {
        property = "id"
    }
    hidden name: ProfileResolvable = (this) {
        property = "name"
    }
}

/// Pricing tier for the profile.
class SKU {
    /// Standard_AzureFrontDoor selects Azure Front Door Standard.
    name: ("Standard_AzureFrontDoor"|"Premium_AzureFrontDoor") = "Standard_AzureFrontDoor"
}

@azure.ResourceHint {
    type = module.type
    identifier = "id"
    apiVersion = module.apiVersion
    parent = "AZURE::Resources::ResourceGroup"
    listParam = new formae.ListProperty { parentProperty = "name" listParameter = "resourceGroupName" }
}
open class Profile extends formae.Resource {

    /// Front Door profile name (unique within the resource group).
    @azure.FieldHint { required = true; createOnly = true }
    name: String(length >= 1 && length <= 260)

    /// Always "global" for Azure Front Door Standard profiles.
    @azure.FieldHint { required = true; createOnly = true }
    location: azure.Location = "global"

    @azure.FieldHint { required = true; createOnly = true }
    resourceGroupName: String(length >= 1 && length <= 90)|formae.Resolvable

    /// Pricing tier. The SKU is immutable after creation.
    @azure.FieldHint { required = true; createOnly = true }
    sku: SKU = new SKU {}

    /// Send/receive timeout (seconds) when forwarding a request to the origin.
    @azure.FieldHint {}
    originResponseTimeoutSeconds: Int(this >= 16 && this <= 240)?

    @azure.FieldHint { outputField = "Tags"; updateMethod = "EntitySet"; indexField = "Key" }
    tags: Listing<azure.Tag>?

    hidden parent = this

    hidden res: ProfileResolvable = new {
        label = parent.label
        stack = parent.stack?.label
    }
}
