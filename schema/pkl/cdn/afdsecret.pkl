module azure.cdn.afdsecret

import "@formae/formae.pkl"
import "../azure.pkl"

const type = "AZURE::Cdn::Secret"
const apiVersion = "2023-05-01"

open class SecretResolvable extends formae.Resolvable {
    hidden type = module.type

    hidden id: SecretResolvable = (this) {
        property = "id"
    }
    hidden name: SecretResolvable = (this) {
        property = "name"
    }
}

@azure.ResourceHint {
    type = module.type
    identifier = "id"
    apiVersion = module.apiVersion
    parent = "AZURE::Cdn::Profile"
    listParam = List(
        new formae.ListProperty { parentProperty = "name" listParameter = "profileName" },
        new formae.ListProperty { parentProperty = "resourceGroupName" listParameter = "resourceGroupName" }
    )
}
open class Secret extends formae.Resource {

    /// Secret resource name (unique within the profile).
    @azure.FieldHint { required = true; createOnly = true }
    name: String(length >= 1 && length <= 260)

    @azure.FieldHint { required = true; createOnly = true }
    resourceGroupName: String(length >= 1 && length <= 90)|formae.Resolvable

    /// Name of the Front Door profile that holds this secret.
    @azure.FieldHint { required = true; createOnly = true }
    profileName: String|formae.Resolvable

    /// Reference to the Key Vault certificate backing this secret. Supply the
    /// certificate's secret id (e.g. cert.res.secretId) for a BYO TLS
    /// (CustomerCertificate) secret.
    @azure.FieldHint { required = true }
    secretSource: String|formae.Resolvable

    /// Specific certificate version to use. Omit to track the latest version.
    @azure.FieldHint {}
    secretVersion: String?

    /// Whether to always use the latest certificate version.
    @azure.FieldHint {}
    useLatestVersion: Boolean?

    /// Optional subject alternative names for the certificate.
    @azure.FieldHint {}
    subjectAlternativeNames: Listing<String>?

    hidden parent = this

    hidden res: SecretResolvable = new {
        label = parent.label
        stack = parent.stack?.label
    }
}
