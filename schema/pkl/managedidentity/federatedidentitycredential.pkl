module azure.managedidentity.federatedidentitycredential

import "@formae/formae.pkl"
import "../azure.pkl"

const type = "Azure::ManagedIdentity::FederatedIdentityCredential"
const apiVersion = "2023-01-31"

open class FederatedIdentityCredentialResolvable extends formae.Resolvable {
    hidden type = module.type

    hidden id: FederatedIdentityCredentialResolvable = (this) {
        property = "id"
    }
    hidden name: FederatedIdentityCredentialResolvable = (this) {
        property = "name"
    }
}

@azure.ResourceHint {
    type = module.type
    identifier = "id"
    apiVersion = module.apiVersion
    parent = "Azure::ManagedIdentity::UserAssignedIdentity"
    listParam = List(
        new formae.ListProperty { parentProperty = "name" listParameter = "userAssignedIdentityName" },
        new formae.ListProperty { parentProperty = "resourceGroupName" listParameter = "resourceGroupName" }
    )
}
open class FederatedIdentityCredential extends formae.Resource {

    @azure.FieldHint { required = true; createOnly = true }
    name: String(length >= 3 && length <= 120 && matches(Regex(#"^[a-zA-Z0-9][-a-zA-Z0-9_]*[a-zA-Z0-9]$"#)))

    @azure.FieldHint { required = true; createOnly = true }
    resourceGroupName: String(length >= 1 && length <= 90)|formae.Resolvable

    /// Name of the parent user-assigned managed identity.
    @azure.FieldHint { required = true; createOnly = true }
    userAssignedIdentityName: String|formae.Resolvable

    /// URL of the OIDC issuer to be trusted (e.g., AKS OIDC issuer URL,
    /// `https://token.actions.githubusercontent.com`).
    @azure.FieldHint { required = true }
    issuer: String

    /// External identifier the issuer asserts (e.g.,
    /// `system:serviceaccount:<namespace>:<sa>` for AKS workload identity,
    /// `repo:<org>/<repo>:ref:refs/heads/main` for GitHub Actions OIDC).
    @azure.FieldHint { required = true }
    subject: String

    /// Audiences allowed in the issued token. Azure currently allows exactly 1 entry,
    /// typically `"api://AzureADTokenExchange"`.
    @azure.FieldHint { required = true }
    audiences: Listing<String>(length == 1)

    hidden parent = this

    hidden res: FederatedIdentityCredentialResolvable = new {
        label = parent.label
        stack = parent.stack?.label
    }
}
