module azure.compute.virtualmachineextension

import "@formae/formae.pkl"
import "../azure.pkl"

const type = "AZURE::Compute::VirtualMachineExtension"
const apiVersion = "2024-03-01"

open class VirtualMachineExtensionResolvable extends formae.Resolvable {
    hidden type = module.type

    hidden id: VirtualMachineExtensionResolvable = (this) {
        property = "id"
    }
    hidden name: VirtualMachineExtensionResolvable = (this) {
        property = "name"
    }
}

@azure.ResourceHint {
    type = module.type
    identifier = "id"
    apiVersion = module.apiVersion
    parent = "AZURE::Compute::VirtualMachine"
    listParam = List(
        new formae.ListProperty { parentProperty = "name" listParameter = "virtualMachineName" },
        new formae.ListProperty { parentProperty = "resourceGroupName" listParameter = "resourceGroupName" }
    )
}
open class VirtualMachineExtension extends formae.Resource {

    // Required properties
    @azure.FieldHint { required = true; createOnly = true }
    name: String(length >= 1 && length <= 80)

    @azure.FieldHint { required = true; createOnly = true }
    resourceGroupName: String(length >= 1 && length <= 90)|formae.Resolvable

    @azure.FieldHint { required = true; createOnly = true }
    virtualMachineName: String(length >= 1 && length <= 64)|formae.Resolvable

    @azure.FieldHint { required = true; createOnly = true }
    location: azure.Location

    /// Name of the extension handler publisher (e.g. "Microsoft.Azure.Extensions")
    @azure.FieldHint { required = true; createOnly = true }
    publisher: String

    /// Extension type (e.g. "CustomScript")
    @azure.FieldHint { required = true; createOnly = true }
    type: String

    /// Version of the extension handler
    @azure.FieldHint {}
    typeHandlerVersion: String?

    /// Use a newer minor version if available at deployment time
    @azure.FieldHint {}
    autoUpgradeMinorVersion: Boolean?

    /// Public settings as free-form JSON
    @azure.FieldHint {}
    settings: Mapping?

    /// Protected settings as free-form JSON (write-only, never returned by Azure)
    @azure.FieldHint { writeOnly = true }
    protectedSettings: Mapping?

    @azure.FieldHint { outputField = "Tags"; updateMethod = "EntitySet"; indexField = "Key" }
    tags: Listing<azure.Tag>?

    hidden parent = this

    hidden res: VirtualMachineExtensionResolvable = new {
        label = parent.label
        stack = parent.stack?.label
    }
}
