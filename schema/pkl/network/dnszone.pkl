module azure.network.dnszone

import "@formae/formae.pkl"
import "../azure.pkl"

const type = "AZURE::Network::DnsZone"
const apiVersion = "2018-05-01"

open class DnsZoneResolvable extends formae.Resolvable {
    hidden type = module.type

    hidden id: DnsZoneResolvable = (this) {
        property = "id"
    }
    hidden name: DnsZoneResolvable = (this) {
        property = "name"
    }
    /// Output-only: the Azure-assigned authoritative name servers for this zone.
    /// Populated on read; use these to configure the domain's registrar delegation.
    hidden nameServers: DnsZoneResolvable = (this) {
        property = "nameServers"
    }
}

@azure.ResourceHint {
    type = module.type
    identifier = "id"
    apiVersion = module.apiVersion
    parent = "AZURE::Resources::ResourceGroup"
    listParam = new formae.ListProperty { parentProperty = "name" listParameter = "resourceGroupName" }
}
open class DnsZone extends formae.Resource {

    /// Fully qualified public DNS zone name (e.g. "example.com").
    @azure.FieldHint { required = true; createOnly = true }
    name: String(length >= 1 && length <= 253)

    /// Always "global" for public DNS zones.
    @azure.FieldHint { required = true; createOnly = true }
    location: azure.Location

    @azure.FieldHint { required = true; createOnly = true }
    resourceGroupName: String(length >= 1 && length <= 90)|formae.Resolvable

    /// The type of this DNS zone. Public zones are internet-facing.
    @azure.FieldHint { createOnly = true }
    zoneType: ("Public"|"Private") = "Public"

    @azure.FieldHint { outputField = "Tags"; updateMethod = "EntitySet"; indexField = "Key" }
    tags: Listing<azure.Tag>?

    hidden parent = this

    hidden res: DnsZoneResolvable = new {
        label = parent.label
        stack = parent.stack?.label
    }
}
