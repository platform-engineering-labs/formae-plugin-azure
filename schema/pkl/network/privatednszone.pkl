module azure.network.privatednszone

import "@formae/formae.pkl"
import "../azure.pkl"

const type = "Azure::Network::PrivateDnsZone"
const apiVersion = "2024-06-01"

open class PrivateDnsZoneResolvable extends formae.Resolvable {
    hidden type = module.type

    hidden id: PrivateDnsZoneResolvable = (this) {
        property = "id"
    }
    hidden name: PrivateDnsZoneResolvable = (this) {
        property = "name"
    }
}

@azure.ResourceHint {
    type = module.type
    identifier = "id"
    apiVersion = module.apiVersion
    parent = "Azure::Resources::ResourceGroup"
    listParam = new formae.ListProperty { parentProperty = "name" listParameter = "resourceGroupName" }
}
open class PrivateDnsZone extends formae.Resource {

    /// Fully qualified zone name (e.g. "privatelink.blob.core.windows.net" or "myzone.internal").
    @azure.FieldHint { required = true; createOnly = true }
    name: String(length >= 1 && length <= 253)

    /// Always "global" for private DNS zones.
    @azure.FieldHint { required = true; createOnly = true }
    location: azure.Location

    @azure.FieldHint { required = true; createOnly = true }
    resourceGroupName: String(length >= 1 && length <= 90)|formae.Resolvable

    @azure.FieldHint { outputField = "Tags"; updateMethod = "EntitySet"; indexField = "Key" }
    tags: Listing<azure.Tag>?

    hidden parent = this

    hidden res: PrivateDnsZoneResolvable = new {
        label = parent.label
        stack = parent.stack?.label
    }
}
