module azure.keyvault.secret

import "@formae/formae.pkl"
import "../azure.pkl"

const type = "AZURE::KeyVault::Secret"
// Data-plane API version (metadata only; the azsecrets SDK pins its own).
const apiVersion = "7.5"

open class SecretResolvable extends formae.Resolvable {
    hidden type = module.type

    hidden id: SecretResolvable = (this) {
        property = "id"
    }
    hidden name: SecretResolvable = (this) {
        property = "name"
    }
    hidden value: SecretResolvable = (this) {
        property = "value"
    }
}

@azure.ResourceHint {
    type = module.type
    identifier = "id"
    apiVersion = module.apiVersion
    parent = "AZURE::KeyVault::Vault"
    // Discovery passes the vault's vaultUri to List as AdditionalProperties["vaultUri"].
    listParam = new formae.ListProperty {
        parentProperty = "vaultUri"
        listParameter = "vaultUri"
    }
}
open class Secret extends formae.Resource {

    @azure.FieldHint { required = true; createOnly = true }
    name: String(matches(Regex("^[0-9a-zA-Z-]+$")) && length >= 1 && length <= 127)

    /// Data-plane URI of the parent Key Vault, e.g. `vaultUri = kv.res.vaultUri`.
    @azure.FieldHint { required = true; createOnly = true }
    vaultUri: String(length >= 1)|formae.Resolvable

    /// The secret value, supplied as formae.value(...).opaque.setOnce; write-only.
    @azure.FieldHint { writeOnly = true; createOnly = true }
    hidden value: (formae.Value|String)?

    /// Content type, e.g. "text/plain".
    @azure.FieldHint {}
    contentType: String?

    @azure.FieldHint { outputField = "Tags"; updateMethod = "EntitySet"; indexField = "Key" }
    tags: Listing<azure.Tag>?

    hidden parent = this

    hidden res: SecretResolvable = new {
        label = parent.label
        stack = parent.stack?.label
    }
}
