amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@azure/azure.pkl"

import "@azure/resources/resourcegroup.pkl"
import "@azure/managedidentity/userassignedidentity.pkl"
import "vars.pkl"

local rg = new resourcegroup.ResourceGroup {
  label = "uai-test-rg"
  name = "formae-plugin-sdk-test-uai-rg-\(vars.testRunID)"
  location = "eastus"
}

forma {
  vars.stack

  vars.target

  rg

  new userassignedidentity.UserAssignedIdentity {
    label = "plugin-sdk-test-uai"
    name = "formae-plugin-sdk-test-uai-\(vars.testRunID)"
    location = "eastus"
    resourceGroupName = rg.res.name
    // Update: Add tags (non-createOnly field)
    tags = new Listing {
      new azure.Tag { key = "Environment"; value = "updated" }
    }
  }
}
