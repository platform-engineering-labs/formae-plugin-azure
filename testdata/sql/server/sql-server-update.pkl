amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@azure/azure.pkl"

import "@azure/resources/resourcegroup.pkl"
import "@azure/sql/server.pkl"

local stackName = "plugin-sdk-test-sql-server-stack"
local testRunID = read("env:FORMAE_TEST_RUN_ID")

local rg = new resourcegroup.ResourceGroup {
  label = "sql-server-test-rg"
  name = "formae-plugin-sdk-test-sql-server-rg-\(testRunID)"
  location = "westus2"
}

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK test for Azure SQL Server"
  }

  new formae.Target {
    label = "azure-target"
    config = new azure.Config {
      subscriptionId = "ddfe7ebf-ba62-442b-b915-24f71b04e63b"
    }
  }

  rg

  new server.Server {
    label = "plugin-sdk-test-sql-server"
    name = "fpsdt-sql-\(testRunID)"
    location = "westus2"
    resourceGroupName = rg.res.name
    administratorLogin = "sqladmin"
    administratorLoginPassword = "T3stP@ssw0rd!"
    version = "12.0"
    // Updatable fields changed to exercise in-place UPDATE:
    minimalTlsVersion = "1.1"
    tags {
      new azure.Tag { key = "Environment"; value = "updated" }
    }
  }
}
