amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@azure/azure.pkl"

import "@azure/resources/resourcegroup.pkl"
import "@azure/sql/server.pkl"
import "@azure/sql/sqlfirewallrule.pkl" as firewallrule

local stackName = "plugin-sdk-test-sql-firewall-rule-stack"
local testRunID = read("env:FORMAE_TEST_RUN_ID")

local rg = new resourcegroup.ResourceGroup {
  label = "sql-fw-test-rg"
  name = "formae-plugin-sdk-test-sql-fw-rg-\(testRunID)"
  location = "westus2"
}

local srv = new server.Server {
  label = "plugin-sdk-test-sql-fw-server"
  name = "fpsdt-sqlfw-\(testRunID)"
  location = "westus2"
  resourceGroupName = rg.res.name
  administratorLogin = "sqladmin"
  administratorLoginPassword = "T3stP@ssw0rd!"
  version = "12.0"
  minimalTlsVersion = "1.2"
}

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK test for Azure SQL Server Firewall Rule"
  }

  new formae.Target {
    label = "azure-target"
    config = new azure.Config {
      subscriptionId = "ddfe7ebf-ba62-442b-b915-24f71b04e63b"
    }
  }

  rg

  srv

  new firewallrule.FirewallRule {
    label = "plugin-sdk-test-sql-firewall-rule"
    name = "fpsdt-sqlfw-rule-\(testRunID)"
    resourceGroupName = rg.res.name
    serverName = srv.res.name
    startIpAddress = "0.0.0.0"
    endIpAddress = "0.0.0.0"
  }
}
