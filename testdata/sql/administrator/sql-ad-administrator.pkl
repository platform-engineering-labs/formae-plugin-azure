amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@azure/azure.pkl"

import "@azure/resources/resourcegroup.pkl"
import "@azure/sql/server.pkl"
import "@azure/sql/administrator.pkl"

local stackName = "plugin-sdk-test-sql-ad-administrator-stack"
local testRunID = read("env:FORMAE_TEST_RUN_ID")

local rg = new resourcegroup.ResourceGroup {
  label = "sql-ad-admin-test-rg"
  name = "formae-plugin-sdk-test-sql-ad-admin-rg-\(testRunID)"
  location = "westus2"
}

local sqlServer = new server.Server {
  label = "plugin-sdk-test-sql-ad-admin-server"
  name = "fpsdt-sqladmin-\(testRunID)"
  location = "westus2"
  resourceGroupName = rg.res.name
  administratorLogin = "sqladmin"
  administratorLoginPassword = "T3stP@ssw0rd!"
  version = "12.0"
}

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK test for Azure SQL Server AAD administrator"
  }

  new formae.Target {
    label = "azure-target"
    config = new azure.Config {
      subscriptionId = "ddfe7ebf-ba62-442b-b915-24f71b04e63b"
    }
  }

  rg

  sqlServer

  new administrator.Administrator {
    label = "plugin-sdk-test-sql-ad-administrator"
    resourceGroupName = rg.res.name
    serverName = sqlServer.res.name
    // Placeholder AAD identity values — replace with real principal at apply time.
    login = "dba-admins"
    sid = "00000000-0000-0000-0000-000000000000"
    tenantId = "11111111-1111-1111-1111-111111111111"
  }
}
