amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@azure/azure.pkl"

import "@azure/resources/resourcegroup.pkl"
import "@azure/network/networksecuritygroup.pkl"
import "vars.pkl"

local rg = new resourcegroup.ResourceGroup {
  label = "nsg-test-rg"
  name = "formae-plugin-sdk-test-nsg-rg-\(vars.testRunID)"
  location = "eastus"
}

forma {
  vars.stack

  vars.target

  rg

  new networksecuritygroup.NetworkSecurityGroup {
    label = "plugin-sdk-test-nsg"
    name = "formae-plugin-sdk-test-nsg-\(vars.testRunID)"
    location = "eastus"
    resourceGroupName = rg.res.name
    // Update: Add tags (non-createOnly field)
    tags = new Listing {
      new azure.Tag { key = "Environment"; value = "updated" }
    }
  }
}
