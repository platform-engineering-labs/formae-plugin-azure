amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@azure/azure.pkl"

import "@azure/resources/resourcegroup.pkl"
import "@azure/storage/storageaccount.pkl"
import "@azure/eventgrid/systemtopic.pkl"
import "vars.pkl"

// Read the test run ID from environment variable set by the test harness
// This ensures consistent naming within a test run but unique names between runs

local rg = new resourcegroup.ResourceGroup {
  label = "egst-test-rg"
  name = "formae-plugin-sdk-test-egst-rg-\(vars.testRunID)"
  location = "eastus"
}

local saSku = new storageaccount.StorageAccountSKU {
  name = "Standard_LRS"
}

local sa = new storageaccount.StorageAccount {
  label = "egst-test-sa"
  name = "fpsdtegst\(vars.testRunID)"
  location = "eastus"
  resourceGroupName = rg.res.name
  sku = saSku
  kind = "StorageV2"
}

forma {
  vars.stack

  vars.target

  rg

  sa

  new systemtopic.SystemTopic {
    label = "plugin-sdk-test-egst"
    name = "fpsdt-egst-\(vars.testRunID)"
    location = "eastus"
    resourceGroupName = rg.res.name
    source = sa.res.id
    topicType = "Microsoft.Storage.StorageAccounts"
  }
}
