amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@azure/azure.pkl"

import "@azure/resources/resourcegroup.pkl"
import "@azure/cdn/profile.pkl"
import "@azure/cdn/afdorigingroup.pkl"
import "vars.pkl"

// NOTE: Stands up a Front Door profile + origin group. Profile provisioning is
// slow and billed; CI-coverable (no secrets, no real domain).

local rg = new resourcegroup.ResourceGroup {
  label = "cdn-test-rg"
  name = "formae-plugin-sdk-test-cdn-og-rg-\(vars.testRunID)"
  location = "eastus"
}

local afdProfile = new profile.Profile {
  label = "plugin-sdk-test-cdn-og-profile"
  name = "formae-sdk-afd-og-\(vars.testRunID)"
  location = "global"
  sku = new profile.SKU { name = "Standard_AzureFrontDoor" }
  resourceGroupName = rg.res.name
}

forma {
  vars.stack

  vars.target

  rg

  afdProfile

  new afdorigingroup.AFDOriginGroup {
    label = "plugin-sdk-test-cdn-origin-group"
    name = "og-\(vars.testRunID)"
    resourceGroupName = rg.res.name
    profileName = afdProfile.res.name
    loadBalancingSettings = new afdorigingroup.LoadBalancingSettings {
      sampleSize = 4
      successfulSamplesRequired = 3
      additionalLatencyInMilliseconds = 100
    }
    healthProbeSettings = new afdorigingroup.HealthProbeSettings {
      probePath = "/"
      probeRequestType = "HEAD"
      probeProtocol = "Https"
      probeIntervalInSeconds = 120
    }
  }
}
