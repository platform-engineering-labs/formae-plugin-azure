amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@azure/azure.pkl"

import "@azure/resources/resourcegroup.pkl"
import "@azure/cognitiveservices/account.pkl"

local stackName = "plugin-sdk-test-cog-stack"
// Read the test run ID from environment variable set by the test harness
// This ensures consistent naming within a test run but unique names between runs
local testRunID = read("env:FORMAE_TEST_RUN_ID")

local rg = new resourcegroup.ResourceGroup {
  label = "cog-test-rg"
  name = "formae-plugin-sdk-test-cog-rg-\(testRunID)"
  location = "eastus"
}

// Define sku as local to avoid SDK test patch logic targeting it
local accountSku = new account.AccountSKU {
  name = "S0"
}

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK test for Azure CognitiveServices Account"
  }

  new formae.Target {
    label = "azure-target"
    config = new azure.Config {
      subscriptionId = "ddfe7ebf-ba62-442b-b915-24f71b04e63b"
    }
  }

  rg

  new account.Account {
    label = "plugin-sdk-test-cog"
    name = "fpsdtcog\(testRunID)"
    location = "eastus"
    resourceGroupName = rg.res.name
    kind = "OpenAI"
    sku = accountSku
  }
}
