amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@azure/azure.pkl"

import "@azure/resources/resourcegroup.pkl"
import "@azure/keyvault/vault.pkl"
import "@azure/keyvault/certificate.pkl"
import "@azure/cdn/profile.pkl"
import "@azure/cdn/afdsecret.pkl"
import "vars.pkl"

// MANUAL-GATE (NOT CI-coverable): A Front Door Secret wraps a REAL Key Vault
// certificate for BYO TLS. It requires (1) a Key Vault whose access policy /
// RBAC grants the Azure Front Door service principal (Microsoft.AzureFrontDoor-
// Cdn, appId ad0e1c7e-6d38-4ba4-9efd-0bc77ba9f037) GET on secrets/certificates,
// and (2) a certificate actually issued in that vault (a data-plane op needing
// "Key Vault Certificates Officer"). Front Door validates it can read the cert
// at create time, so a placeholder secretSource fails. The KV-cert reference
// marshalling is covered by the plugin's marshaller round-trip unit test. To run
// manually, grant the AFD principal vault access, then apply this fixture; the
// Secret's secretSource is wired to cert.res.secretId below.

local azureTenantId = "35412a0c-6726-4fc9-98ef-6e91adcb8d0e"

local rg = new resourcegroup.ResourceGroup {
  label = "cdn-secret-test-rg"
  name = "formae-plugin-sdk-test-cdn-secret-rg-\(vars.testRunID)"
  location = "eastus"
}

local kv = new vault.Vault {
  label = "cdn-secret-test-kv"
  name = "fpsdt-kv-sec-\(vars.testRunID)"
  location = "eastus"
  resourceGroupName = rg.res.name
  tenantId = azureTenantId
  sku = new vault.VaultSKU { family = "A"; name = "standard" }
  enableSoftDelete = true
  softDeleteRetentionInDays = 7
  enableRbacAuthorization = true
}

local cert = new certificate.Certificate {
  label = "cdn-secret-test-cert"
  name = "fpsdt-cert-\(vars.testRunID)"
  vaultUri = kv.res.vaultUri
  policy = new certificate.Policy {
    issuerName = "Self"
    subject = "CN=formae-test"
    keyType = "RSA"
    validityMonths = 12
  }
}

local afdProfile = new profile.Profile {
  label = "cdn-secret-test-profile"
  name = "formae-sdk-afd-secret-\(vars.testRunID)"
  location = "Global"
  sku = new profile.SKU { name = "Standard_AzureFrontDoor" }
  resourceGroupName = rg.res.name
}

forma {
  vars.stack

  vars.target

  rg
  kv
  cert
  afdProfile

  new afdsecret.Secret {
    label = "cdn-secret-test-secret"
    name = "sec-\(vars.testRunID)"
    resourceGroupName = rg.res.name
    profileName = afdProfile.res.name
    secretSource = cert.res.secretId
    useLatestVersion = false
    secretVersion = "REPLACE_WITH_CERT_VERSION"
  }
}
