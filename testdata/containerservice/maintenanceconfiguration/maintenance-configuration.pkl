amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@azure/azure.pkl"

import "@azure/resources/resourcegroup.pkl"
import "@azure/containerservice/managedcluster.pkl"
import "@azure/containerservice/maintenanceconfiguration.pkl"

local stackName = "plugin-sdk-test-mc-stack"
local testRunID = read("env:FORMAE_TEST_RUN_ID")

local rg = new resourcegroup.ResourceGroup {
  label = "mc-test-rg"
  name = "formae-plugin-sdk-test-mc-rg-\(testRunID)"
  location = "eastus"
}

local cluster = new managedcluster.ManagedCluster {
  label = "mc-test-aks"
  name = "fpsdt-mc-aks-\(testRunID)"
  location = "eastus"
  resourceGroupName = rg.res.name
  sku = new managedcluster.ManagedClusterSKU {
    name = "Base"
    tier = "Free"
  }
  identity = new managedcluster.ManagedClusterIdentity {
    type = "SystemAssigned"
  }
  dnsPrefix = "fpsdt-mc-aks-\(testRunID)"
  agentPoolProfiles = new Listing {
    new managedcluster.AgentPoolProfile {
      name = "nodepool1"
      count = 1
      vmSize = "Standard_D2s_v4"
      mode = "System"
      osType = "Linux"
    }
  }
}

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK test for Azure MaintenanceConfiguration"
  }

  new formae.Target {
    label = "azure-target"
    config = new azure.Config {
      subscriptionId = "ddfe7ebf-ba62-442b-b915-24f71b04e63b"
    }
  }

  rg

  cluster

  new maintenanceconfiguration.MaintenanceConfiguration {
    label = "plugin-sdk-test-mc"
    name = "default"
    resourceGroupName = rg.res.name
    clusterName = cluster.res.name
    timeInWeek = new Listing {
      new maintenanceconfiguration.TimeInWeek {
        day = "Tuesday"
        hourSlots = new Listing { 1; 2; 3; 4 }
      }
    }
  }
}
