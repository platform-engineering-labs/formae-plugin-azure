amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@azure/azure.pkl"

import "@azure/resources/resourcegroup.pkl"
import "@azure/sql/server.pkl"
import "@azure/sql/sqldatabase.pkl" as database
import "vars.pkl"

local rg = new resourcegroup.ResourceGroup {
  label = "sql-database-test-rg"
  name = "formae-plugin-sdk-test-sql-database-rg-\(vars.testRunID)"
  location = "westus2"
}

local srv = new server.Server {
  label = "plugin-sdk-test-sql-database-server"
  name = "fpsdt-sqldb-\(vars.testRunID)"
  location = "westus2"
  resourceGroupName = rg.res.name
  administratorLogin = "sqladmin"
  administratorLoginPassword = "T3stP@ssw0rd!"
  version = "12.0"
  minimalTlsVersion = "1.2"
}

forma {
  vars.stack

  vars.target

  rg

  srv

  new database.Database {
    label = "plugin-sdk-test-sql-database"
    name = "fpsdt-db-\(vars.testRunID)"
    location = "westus2"
    resourceGroupName = rg.res.name
    serverName = srv.res.name
    collation = "SQL_Latin1_General_CP1_CI_AS"
    // Scale up DTU capacity (10 -> 20, i.e. S0 -> S1) to exercise the Update
    // path. name stays "Standard": Azure returns the tier name, not "S1".
    sku = new database.SKU {
      name = "Standard"
      tier = "Standard"
      capacity = 20
    }
  }
}
