amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@azure/azure.pkl"

import "@azure/resources/resourcegroup.pkl"
import "@azure/dashboard/grafana.pkl"
import "@azure/dashboard/grafanamanagedprivateendpoint.pkl"

local stackName = "plugin-sdk-test-grafana-mpe-stack"
local testRunID = read("env:FORMAE_TEST_RUN_ID")

local rg = new resourcegroup.ResourceGroup {
  label = "grafana-mpe-test-rg"
  name = "formae-plugin-sdk-test-grafana-mpe-rg-\(testRunID)"
  location = "eastus"
}

local grafanaSku = new grafana.GrafanaSKU {
  name = "Standard"
}

local workspace = new grafana.Grafana {
  label = "grafana-mpe-test-grafana"
  name = "fpsdtgmpe\(testRunID)"
  location = "eastus"
  resourceGroupName = rg.res.name
  sku = grafanaSku
  apiKey = "Disabled"
}

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK test for Azure Grafana Managed Private Endpoint"
  }

  new formae.Target {
    label = "azure-target"
    config = new azure.Config {
      subscriptionId = "ddfe7ebf-ba62-442b-b915-24f71b04e63b"
    }
  }

  rg

  workspace

  new grafanamanagedprivateendpoint.GrafanaManagedPrivateEndpoint {
    label = "plugin-sdk-test-grafana-mpe"
    name = "fpsdtgmpe\(testRunID)"
    location = "eastus"
    resourceGroupName = rg.res.name
    workspaceName = workspace.res.name
    privateLinkResourceId = "/subscriptions/ddfe7ebf-ba62-442b-b915-24f71b04e63b/resourceGroups/formae-plugin-sdk-test-grafana-mpe-rg-\(testRunID)/providers/Microsoft.Storage/storageAccounts/fpsdtgmpesa\(testRunID)"
    privateLinkResourceRegion = "eastus"
    groupIds = new Listing { "blob" }
    requestMessage = "formae plugin sdk test"
    // Update: add tags (mutable field)
    tags = new Listing {
      new azure.Tag { key = "Environment"; value = "updated" }
    }
  }
}
