amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@azure/azure.pkl"

import "@azure/resources/resourcegroup.pkl"
import "@azure/dashboard/grafana.pkl"

local stackName = "plugin-sdk-test-grafana-stack"
local testRunID = read("env:FORMAE_TEST_RUN_ID")

local rg = new resourcegroup.ResourceGroup {
  label = "grafana-test-rg"
  name = "formae-plugin-sdk-test-grafana-rg-\(testRunID)"
  location = "eastus"
}

local grafanaSku = new grafana.GrafanaSKU {
  name = "Standard"
}

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK test for Azure Managed Grafana"
  }

  new formae.Target {
    label = "azure-target"
    config = new azure.Config {
      subscriptionId = "ddfe7ebf-ba62-442b-b915-24f71b04e63b"
    }
  }

  rg

  // Replace: change name (createOnly field triggers delete+create)
  new grafana.Grafana {
    label = "plugin-sdk-test-grafana"
    name = "grfr\(testRunID)"
    location = "eastus"
    resourceGroupName = rg.res.name
    sku = grafanaSku
    apiKey = "Disabled"
  }
}
