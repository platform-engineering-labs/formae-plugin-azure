amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@azure/azure.pkl"

import "@azure/resources/resourcegroup.pkl"
import "@azure/containerservice/managedcluster.pkl"
import "@azure/kubernetesconfiguration/extension.pkl"

local stackName = "plugin-sdk-test-ext-stack"
local testRunID = read("env:FORMAE_TEST_RUN_ID")

local rg = new resourcegroup.ResourceGroup {
  label = "ext-test-rg"
  name = "formae-plugin-sdk-test-ext-rg-\(testRunID)"
  location = "eastus"
}

local cluster = new managedcluster.ManagedCluster {
  label = "ext-test-aks"
  name = "fpsdt-ext-aks-\(testRunID)"
  location = "eastus"
  resourceGroupName = rg.res.name
  sku = new managedcluster.ManagedClusterSKU {
    name = "Base"
    tier = "Free"
  }
  identity = new managedcluster.ManagedClusterIdentity {
    type = "SystemAssigned"
  }
  dnsPrefix = "fpsdt-ext-aks-\(testRunID)"
  agentPoolProfiles = new Listing {
    new managedcluster.AgentPoolProfile {
      name = "nodepool1"
      count = 1
      vmSize = "Standard_D2s_v4"
      mode = "System"
      osType = "Linux"
    }
  }
}

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK test for Azure Kubernetes Extension"
  }

  new formae.Target {
    label = "azure-target"
    config = new azure.Config {
      subscriptionId = "ddfe7ebf-ba62-442b-b915-24f71b04e63b"
    }
  }

  rg

  cluster

  // Replace: Change name (createOnly field triggers delete+create)
  new extension.Extension {
    label = "plugin-sdk-test-flux-ext"
    name = "flux-replaced"
    resourceGroupName = rg.res.name
    clusterName = cluster.res.name
    extensionType = "microsoft.flux"
    autoUpgradeMinorVersion = true
  }
}
