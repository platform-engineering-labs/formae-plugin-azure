amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@azure/azure.pkl"

import "@azure/resources/resourcegroup.pkl"
import "@azure/containerservice/managedcluster.pkl"
import "@azure/kubernetesconfiguration/extension.pkl"
import "vars.pkl"

local rg = new resourcegroup.ResourceGroup {
  label = "ext-test-rg"
  name = "formae-plugin-sdk-test-ext-rg-\(vars.testRunID)"
  location = "eastus"
}

local cluster = new managedcluster.ManagedCluster {
  label = "ext-test-aks"
  name = "fpsdt-ext-aks-\(vars.testRunID)"
  location = "eastus"
  resourceGroupName = rg.res.name
  sku = new managedcluster.ManagedClusterSKU {
    name = "Base"
    tier = "Free"
  }
  identity = new managedcluster.ManagedClusterIdentity {
    type = "SystemAssigned"
  }
  dnsPrefix = "fpsdt-ext-aks-\(vars.testRunID)"
  agentPoolProfiles = new Listing {
    new managedcluster.AgentPoolProfile {
      name = "nodepool1"
      count = 1
      vmSize = "Standard_D2s_v4"
      mode = "System"
      osType = "Linux"
    }
  }
}

forma {
  vars.stack

  vars.target

  rg

  cluster

  new extension.Extension {
    label = "plugin-sdk-test-flux-ext"
    name = "flux"
    resourceGroupName = rg.res.name
    clusterName = cluster.res.name
    extensionType = "microsoft.flux"
    autoUpgradeMinorVersion = true
  }
}
