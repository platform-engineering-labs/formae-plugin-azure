amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@azure/azure.pkl"

import "@azure/resources/resourcegroup.pkl"
import "@azure/containerregistry/registry.pkl"
import "vars.pkl"

local rg = new resourcegroup.ResourceGroup {
  label = "acr-test-rg"
  name = "formae-plugin-sdk-test-acr-rg-\(vars.testRunID)"
  location = "eastus"
}

local registrySku = new registry.RegistrySKU {
  name = "Basic"
}

forma {
  vars.stack

  vars.target

  rg

  new registry.Registry {
    label = "plugin-sdk-test-acr"
    name = "fpsdtacr\(vars.testRunID)"
    location = "eastus"
    resourceGroupName = rg.res.name
    sku = registrySku
    // Update: Add tags (non-createOnly field)
    tags = new Listing {
      new azure.Tag { key = "Environment"; value = "updated" }
    }
  }
}
