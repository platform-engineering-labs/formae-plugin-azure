amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@azure/azure.pkl"

import "@azure/resources/resourcegroup.pkl"
import "@azure/storage/storageaccount.pkl"
import "@azure/storage/blobcontainer.pkl"

local stackName = "plugin-sdk-test-bc-stack"
local testRunID = read("env:FORMAE_TEST_RUN_ID")

local rg = new resourcegroup.ResourceGroup {
  label = "bc-test-rg"
  name = "formae-plugin-sdk-test-bc-rg-\(testRunID)"
  location = "eastus"
}

local saSku = new storageaccount.StorageAccountSKU {
  name = "Standard_LRS"
}

local sa = new storageaccount.StorageAccount {
  label = "bc-test-sa"
  name = "fpsdtbc\(testRunID)"
  location = "eastus"
  resourceGroupName = rg.res.name
  sku = saSku
  kind = "StorageV2"
}

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK test for Azure BlobContainer"
  }

  new formae.Target {
    label = "azure-target"
    config = new azure.Config {
      subscriptionId = "ddfe7ebf-ba62-442b-b915-24f71b04e63b"
    }
  }

  rg
  sa

  new blobcontainer.BlobContainer {
    label = "plugin-sdk-test-bc"
    name = "plugin-sdk-test-bc-\(testRunID)"
    resourceGroupName = rg.res.name
    storageAccountName = sa.res.name
    publicAccess = "None"
  }
}
