amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@azure/azure.pkl"

import "@azure/resources/resourcegroup.pkl"
import "@azure/cognitiveservices/account.pkl"
import "vars.pkl"

// Read the test run ID from environment variable set by the test harness
// This ensures consistent naming within a test run but unique names between runs

local rg = new resourcegroup.ResourceGroup {
  label = "cog-test-rg"
  name = "formae-plugin-sdk-test-cog-rg-\(vars.testRunID)"
  location = "eastus"
}

// Define sku as local to avoid SDK test patch logic targeting it
local accountSku = new account.AccountSKU {
  name = "S0"
}

forma {
  vars.stack

  vars.target

  rg

  new account.Account {
    label = "plugin-sdk-test-cog"
    name = "fpsdtcog\(vars.testRunID)"
    location = "eastus"
    resourceGroupName = rg.res.name
    kind = "OpenAI"
    sku = accountSku
  }
}
