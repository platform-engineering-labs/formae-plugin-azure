amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@azure/azure.pkl"

import "@azure/resources/resourcegroup.pkl"
import "@azure/keyvault/vault.pkl"
import "@azure/keyvault/secret.pkl"

local stackName = "plugin-sdk-test-kv-secret-stack"
local testRunID = read("env:FORMAE_TEST_RUN_ID")
local azureTenantId = "35412a0c-6726-4fc9-98ef-6e91adcb8d0e"

local rg = new resourcegroup.ResourceGroup {
  label = "kv-secret-test-rg"
  name = "formae-plugin-sdk-test-kv-secret-rg-\(testRunID)"
  location = "eastus"
}

local vaultSku = new vault.VaultSKU {
  family = "A"
  name = "standard"
}

local kv = new vault.Vault {
  label = "kv-secret-test-kv"
  name = "fpsdt-kv-sec-\(testRunID)"
  location = "eastus"
  resourceGroupName = rg.res.name
  tenantId = azureTenantId
  sku = vaultSku
  enableSoftDelete = true
  softDeleteRetentionInDays = 7
  enableRbacAuthorization = true
}

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK test for Azure KeyVault Secret"
  }

  new formae.Target {
    label = "azure-target"
    config = new azure.Config {
      subscriptionId = "ddfe7ebf-ba62-442b-b915-24f71b04e63b"
    }
  }

  rg
  kv

  // Replace: change the secret name (createOnly) to force delete+create.
  // NativeID changes (versionless id includes the name), proving a replace.
  new secret.Secret {
    label = "kv-secret-test-secret"
    name = "fpsdt-secret-rpl-\(testRunID)"
    vaultUri = kv.res.vaultUri
    value = formae.value("initial-secret-value").opaque.setOnce
    contentType = "text/plain"
  }
}
