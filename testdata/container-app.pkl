amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@azure/azure.pkl"

import "@azure/resources/resourcegroup.pkl"
import "@azure/app/managedenvironment.pkl"
import "@azure/app/containerapp.pkl"

import "vars.pkl"

// NOTE: This fixture runs a PUBLIC image with a plain env var and NO secrets.
// Container secret `value` is write-only — Azure never returns it on read, so
// the conformance harness (desired vs read-back, cannot strip a write-only field
// nested in an array) would report false drift. The secret path is covered by
// the plugin's marshaller round-trip unit test and by a manual live gate.
//
// SLOW + BILLED: the managed environment alone takes ~5 minutes to provision and
// may exceed the CI 10-minute command timeout (like the AKS extension). Likely
// warrants exclusion from the default CI matrix; validate via `make
// test-integration` + a manual `make conformance-test-crud TEST=container-app`.

local rg = new resourcegroup.ResourceGroup {
  label = "container-app-test-rg"
  name = "formae-plugin-sdk-test-capp-rg-\(vars.testRunID)"
  location = "eastus"
}

local env = new managedenvironment.ManagedEnvironment {
  label = "container-app-test-env"
  name = "formae-plugin-sdk-test-capp-env-\(vars.testRunID)"
  location = "eastus"
  resourceGroupName = rg.res.name
}

forma {
  vars.stack

  vars.target

  rg
  env

  new containerapp.ContainerApp {
    label = "plugin-sdk-test-container-app"
    name = "capp-\(vars.testRunID)"
    location = "eastus"
    resourceGroupName = rg.res.name
    managedEnvironmentId = env.res.id
    configuration = new containerapp.Configuration {
      ingress = new containerapp.Ingress {
        `external` = true
        targetPort = 80
      }
    }
    template = new containerapp.Template {
      containers = new Listing {
        new containerapp.Container {
          name = "main"
          image = "mcr.microsoft.com/k8se/quickstart:latest"
          resources = new containerapp.ContainerResources {
            cpu = 0.5
            memory = "1Gi"
          }
          env = new Listing {
            new containerapp.EnvironmentVar { name = "GREETING"; value = "hello" }
          }
        }
      }
      scale = new containerapp.Scale {
        minReplicas = 0
        maxReplicas = 1
      }
    }
  }
}
