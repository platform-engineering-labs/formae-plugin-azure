import "@formae/formae.pkl"
import "@azure/azure.pkl"


local stackName = "plugin-sdk-test-stack"


testRunID = read("env:FORMAE_TEST_RUN_ID")
local subscriptionIdEnv =  read("env:AZURE_SUBSCRIPTION_ID")

stack = new formae.Stack {
    label = stackName
    description = "Plugin SDK test for GCP Compute Disk"
}

target = new formae.Target {
    label = "azure-target"
    config = new azure.Config {
      subscriptionId = subscriptionIdEnv
    }
}