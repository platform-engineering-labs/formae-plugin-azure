amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@azure/azure.pkl"

import "@azure/resources/resourcegroup.pkl"
import "@azure/sql/server.pkl"
import "vars.pkl"

local rg = new resourcegroup.ResourceGroup {
  label = "sql-server-test-rg"
  name = "formae-plugin-sdk-test-sql-server-rg-\(vars.testRunID)"
  location = "westus2"
}

forma {
  vars.stack

  vars.target

  rg

  new server.Server {
    label = "plugin-sdk-test-sql-server"
    name = "fpsdt-sql-\(vars.testRunID)"
    location = "westus2"
    resourceGroupName = rg.res.name
    administratorLogin = "sqladmin"
    administratorLoginPassword = "T3stP@ssw0rd!"
    version = "12.0"
    minimalTlsVersion = "1.2"
    // Tag addition exercises the in-place UPDATE path. minimalTlsVersion stays at
    // 1.2 because Azure rejects anything below 1.2 (TLS 1.0/1.1 retired Nov 2024).
    tags {
      new azure.Tag { key = "Environment"; value = "updated" }
    }
  }
}
