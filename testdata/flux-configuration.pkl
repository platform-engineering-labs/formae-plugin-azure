amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@azure/azure.pkl"

import "@azure/resources/resourcegroup.pkl"
import "@azure/containerservice/managedcluster.pkl"
import "@azure/kubernetesconfiguration/extension.pkl"
import "@azure/kubernetesconfiguration/fluxconfiguration.pkl"
import "vars.pkl"

local rg = new resourcegroup.ResourceGroup {
  label = "flux-test-rg"
  name = "formae-plugin-sdk-test-flux-rg-\(vars.testRunID)"
  location = "eastus"
}

local cluster = new managedcluster.ManagedCluster {
  label = "flux-test-aks"
  name = "fpsdt-flux-aks-\(vars.testRunID)"
  location = "eastus"
  resourceGroupName = rg.res.name
  sku = new managedcluster.ManagedClusterSKU {
    name = "Base"
    tier = "Free"
  }
  identity = new managedcluster.ManagedClusterIdentity {
    type = "SystemAssigned"
  }
  dnsPrefix = "fpsdt-flux-aks-\(vars.testRunID)"
  agentPoolProfiles = new Listing {
    new managedcluster.AgentPoolProfile {
      name = "nodepool1"
      count = 1
      vmSize = "Standard_D2s_v4"
      mode = "System"
      osType = "Linux"
    }
  }
}

local fluxExt = new extension.Extension {
  label = "flux-ext"
  name = "flux"
  resourceGroupName = rg.res.name
  clusterName = cluster.res.name
  extensionType = "microsoft.flux"
  autoUpgradeMinorVersion = true
}

forma {
  vars.stack

  vars.target

  rg

  cluster

  fluxExt

  new fluxconfiguration.FluxConfiguration {
    label = "plugin-sdk-test-flux-config"
    name = "flux-system"
    resourceGroupName = rg.res.name
    clusterName = cluster.res.name
    sourceKind = "GitRepository"
    namespace = "flux-system"
    scope = "cluster"
    gitRepository = new fluxconfiguration.GitRepository {
      url = "https://github.com/Azure/gitops-flux2-kustomize-helm-mt"
      repositoryRef = new fluxconfiguration.RepositoryRef {
        branch = "main"
      }
      syncIntervalInSeconds = 120
    }
    kustomizations = new Mapping {
      ["infra"] = new fluxconfiguration.Kustomization {
        path = "./infrastructure"
        prune = true
      }
    }
  }
}
