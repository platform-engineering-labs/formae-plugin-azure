amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@azure/azure.pkl"

import "@azure/resources/resourcegroup.pkl"
import "@azure/servicebus/servicebusnamespace.pkl" as namespace
import "vars.pkl"

local rg = new resourcegroup.ResourceGroup {
  label = "sbns-test-rg"
  name = "formae-plugin-sdk-test-sbns-rg-\(vars.testRunID)"
  location = "eastus"
}

local namespaceSku = new namespace.NamespaceSKU {
  name = "Standard"
}

forma {
  vars.stack

  vars.target

  rg

  new namespace.Namespace {
    label = "plugin-sdk-test-sbns"
    name = "fpsdt-sbns-\(vars.testRunID)"
    location = "eastus"
    resourceGroupName = rg.res.name
    sku = namespaceSku
    // Update: Add tags (non-createOnly field)
    tags = new Listing {
      new azure.Tag { key = "Environment"; value = "updated" }
    }
  }
}
