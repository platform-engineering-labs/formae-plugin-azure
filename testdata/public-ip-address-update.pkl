amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@azure/azure.pkl"

import "@azure/resources/resourcegroup.pkl"
import "@azure/network/publicipaddress.pkl"
import "vars.pkl"

local rg = new resourcegroup.ResourceGroup {
  label = "pip-test-rg"
  name = "formae-plugin-sdk-test-pip-rg-\(vars.testRunID)"
  location = "eastus"
}

local pipSku = new publicipaddress.PublicIPAddressSKU {
  name = "Standard"
  tier = "Regional"
}

forma {
  vars.stack

  vars.target

  rg

  new publicipaddress.PublicIPAddress {
    label = "plugin-sdk-test-pip"
    name = "formae-plugin-sdk-test-pip-\(vars.testRunID)"
    location = "eastus"
    resourceGroupName = rg.res.name
    sku = pipSku
    publicIPAllocationMethod = "Static"
    // Update: Add tags (non-createOnly field)
    tags = new Listing {
      new azure.Tag { key = "Environment"; value = "updated" }
    }
  }
}
