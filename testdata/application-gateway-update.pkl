amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@azure/azure.pkl"

import "@azure/resources/resourcegroup.pkl"
import "@azure/resources/virtualnetwork.pkl"
import "@azure/resources/subnet.pkl"
import "@azure/network/publicipaddress.pkl"
import "@azure/network/applicationgateway.pkl"

import "vars.pkl"

// HTTP listener (no cert) — see application-gateway.pkl for why the TLS/cert
// path is not in the conformance fixture.

local rg = new resourcegroup.ResourceGroup {
  label = "appgw-test-rg"
  name = "formae-plugin-sdk-test-appgw-rg-\(vars.testRunID)"
  location = "eastus"
}

local vnetAddressSpace = new virtualnetwork.AddressSpace {
  addressPrefixes = new Listing {
    "10.0.0.0/16"
  }
}

local vnet = new virtualnetwork.VirtualNetwork {
  label = "appgw-test-vnet"
  name = "formae-plugin-sdk-test-appgw-vnet-\(vars.testRunID)"
  location = "eastus"
  resourceGroupName = rg.res.name
  addressSpace = vnetAddressSpace
}

local appgwSubnet = new subnet.Subnet {
  label = "appgw-test-subnet"
  name = "appgw-subnet"
  resourceGroupName = rg.res.name
  virtualNetworkName = vnet.res.name
  addressPrefix = "10.0.1.0/24"
}

local pipSku = new publicipaddress.PublicIPAddressSKU {
  name = "Standard"
  tier = "Regional"
}

local pip = new publicipaddress.PublicIPAddress {
  label = "appgw-test-pip"
  name = "formae-plugin-sdk-test-appgw-pip-\(vars.testRunID)"
  location = "eastus"
  resourceGroupName = rg.res.name
  sku = pipSku
  publicIPAllocationMethod = "Static"
}

forma {
  vars.stack
  vars.target

  rg
  vnet
  appgwSubnet
  pip

  new applicationgateway.ApplicationGateway {
    label = "plugin-sdk-test-appgw"
    name = "formae-plugin-sdk-test-appgw-\(vars.testRunID)"
    location = "eastus"
    resourceGroupName = rg.res.name
    sku = new applicationgateway.ApplicationGatewaySKU {
      name = "Standard_v2"
      tier = "Standard_v2"
      capacity = 1
    }
    gatewayIPConfigurations = new Listing {
      new applicationgateway.GatewayIPConfiguration {
        name = "gwip"
        subnetId = appgwSubnet.res.id
      }
    }
    frontendIPConfigurations = new Listing {
      new applicationgateway.FrontendIPConfiguration {
        name = "feip"
        publicIPAddressId = pip.res.id
      }
    }
    frontendPorts = new Listing {
      new applicationgateway.FrontendPort {
        name = "http"
        port = 80
      }
    }
    backendAddressPools = new Listing {
      new applicationgateway.BackendAddressPool {
        name = "agent-pool"
        // Update: add a second backend member (reconcilable).
        backendAddresses = new Listing {
          new applicationgateway.BackendAddress { ipAddress = "10.0.2.4" }
          new applicationgateway.BackendAddress { ipAddress = "10.0.2.5" }
        }
      }
    }
    backendHttpSettingsCollection = new Listing {
      new applicationgateway.BackendHTTPSettings {
        name = "agent-http"
        port = 49684
        protocol = "Http"
        probeName = "health"
        requestTimeout = 30
        cookieBasedAffinity = "Disabled"
      }
    }
    httpListeners = new Listing {
      new applicationgateway.HTTPListener {
        name = "l80"
        frontendIPConfigurationName = "feip"
        frontendPortName = "http"
        protocol = "Http"
      }
    }
    requestRoutingRules = new Listing {
      new applicationgateway.RequestRoutingRule {
        name = "r1"
        ruleType = "Basic"
        priority = 100
        httpListenerName = "l80"
        backendAddressPoolName = "agent-pool"
        backendHTTPSettingsName = "agent-http"
      }
    }
    probes = new Listing {
      new applicationgateway.Probe {
        name = "health"
        protocol = "Http"
        // Update: change probe path + bump interval (non-createOnly).
        path = "/api/v1/healthz"
        host = "localhost"
        port = 49684
        interval = 60
        timeout = 30
        unhealthyThreshold = 3
      }
    }
    // Update: add tags (non-createOnly).
    tags = new Listing {
      new azure.Tag { key = "Environment"; value = "updated" }
    }
  }
}
