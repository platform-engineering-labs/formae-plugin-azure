amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@azure/azure.pkl"

import "@azure/resources/resourcegroup.pkl"
import "@azure/cdn/profile.pkl"
import "@azure/cdn/afdendpoint.pkl"
import "@azure/cdn/afdorigingroup.pkl"
import "@azure/cdn/afdorigin.pkl"
import "@azure/cdn/route.pkl"
import "vars.pkl"

// NOTE: Stands up a complete, working Azure Front Door Standard stack:
// profile -> endpoint -> origin group -> origin -> route. The route links to
// the origin group by full ARM id (originGroup.res.id) and to the endpoint's
// default domain. Profile provisioning is slow and billed; CI-coverable
// (no secrets, no real custom domain). Use a generous TIMEOUT.

local rg = new resourcegroup.ResourceGroup {
  label = "cdn-test-rg"
  name = "formae-plugin-sdk-test-cdn-route-rg-\(vars.testRunID)"
  location = "eastus"
}

local afdProfile = new profile.Profile {
  label = "plugin-sdk-test-cdn-route-profile"
  name = "formae-sdk-afd-route-\(vars.testRunID)"
  location = "Global"
  sku = new profile.SKU { name = "Standard_AzureFrontDoor" }
  resourceGroupName = rg.res.name
}

local endpoint = new afdendpoint.AFDEndpoint {
  label = "plugin-sdk-test-cdn-route-endpoint"
  name = "ep-\(vars.testRunID)"
  location = "Global"
  resourceGroupName = rg.res.name
  profileName = afdProfile.res.name
  enabledState = "Enabled"
}

local originGroup = new afdorigingroup.AFDOriginGroup {
  label = "plugin-sdk-test-cdn-route-og"
  name = "og-\(vars.testRunID)"
  resourceGroupName = rg.res.name
  profileName = afdProfile.res.name
  loadBalancingSettings = new afdorigingroup.LoadBalancingSettings {
    sampleSize = 4
    successfulSamplesRequired = 3
    additionalLatencyInMilliseconds = 50
  }
  healthProbeSettings = new afdorigingroup.HealthProbeSettings {
    probePath = "/"
    probeRequestType = "HEAD"
    probeProtocol = "Https"
    probeIntervalInSeconds = 100
  }
}

local origin = new afdorigin.AFDOrigin {
  label = "plugin-sdk-test-cdn-route-origin"
  name = "origin-\(vars.testRunID)"
  resourceGroupName = rg.res.name
  profileName = afdProfile.res.name
  originGroupName = originGroup.res.name
  hostName = "www.example.com"
  httpPort = 80
  httpsPort = 443
  originHostHeader = "www.example.com"
  priority = 1
  weight = 1000
  enabledState = "Enabled"
}

forma {
  vars.stack

  vars.target

  rg

  afdProfile

  endpoint

  originGroup

  origin

  new route.Route {
    label = "plugin-sdk-test-cdn-route"
    name = "route-\(vars.testRunID)"
    resourceGroupName = rg.res.name
    profileName = afdProfile.res.name
    endpointName = endpoint.res.name
    originGroupId = originGroup.res.id
    patternsToMatch = new Listing { "/*" }
    supportedProtocols = new Listing { "Http"; "Https" }
    forwardingProtocol = "MatchRequest"
    linkToDefaultDomain = "Enabled"
    httpsRedirect = "Enabled"
  }
}
