amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@azure/azure.pkl"

import "@azure/resources/resourcegroup.pkl"
import "@azure/network/publicipaddress.pkl"
import "vars.pkl"

// Read the test run ID from environment variable set by the test harness
// This ensures consistent naming within a test run but unique names between runs

local rg = new resourcegroup.ResourceGroup {
  label = "pip-test-rg"
  name = "formae-plugin-sdk-test-pip-rg-\(vars.testRunID)"
  location = "eastus"
}

// Define sku as local to avoid SDK test patch logic targeting it
local pipSku = new publicipaddress.PublicIPAddressSKU {
  name = "Standard"
  tier = "Regional"
}

forma {
  vars.stack

  vars.target

  rg

  new publicipaddress.PublicIPAddress {
    label = "plugin-sdk-test-pip"
    name = "formae-plugin-sdk-test-pip-\(vars.testRunID)"
    location = "eastus"
    resourceGroupName = rg.res.name
    sku = pipSku
    publicIPAllocationMethod = "Static"
  }
}
