amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@azure/azure.pkl"

import "@azure/resources/resourcegroup.pkl"
import "@azure/resources/virtualnetwork.pkl"
import "vars.pkl"

// Read the test run ID from environment variable set by the test harness
// This ensures consistent naming within a test run but unique names between runs

local rg = new resourcegroup.ResourceGroup {
  label = "vnet-test-rg"
  name = "formae-plugin-sdk-test-vnet-rg-\(vars.testRunID)"
  location = "eastus"
}

// Define addressSpace as local to avoid SDK test patch logic targeting it
// (SDK test finds last "new Module.Type {" pattern and adds tags there)
local vnetAddressSpace = new virtualnetwork.AddressSpace {
  addressPrefixes = new Listing {
    "10.0.0.0/16"
  }
}

forma {
  vars.stack

  vars.target

  // Resource Group required for VNet
  rg

  // VirtualNetwork under test - uses resolvable reference to RG for dependency
  new virtualnetwork.VirtualNetwork {
    label = "plugin-sdk-test-vnet"
    name = "formae-plugin-sdk-test-vnet-\(vars.testRunID)"
    location = "eastus"
    resourceGroupName = rg.res.name
    addressSpace = vnetAddressSpace
  }
}