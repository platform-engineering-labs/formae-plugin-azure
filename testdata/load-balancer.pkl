amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@azure/azure.pkl"

import "@azure/resources/resourcegroup.pkl"
import "@azure/network/publicipaddress.pkl"
import "@azure/network/loadbalancer.pkl"
import "vars.pkl"

local rg = new resourcegroup.ResourceGroup {
  label = "lb-test-rg"
  name = "formae-plugin-sdk-test-lb-rg-\(vars.testRunID)"
  location = "eastus"
}

local pipSku = new publicipaddress.PublicIPAddressSKU {
  name = "Standard"
  tier = "Regional"
}

local pip = new publicipaddress.PublicIPAddress {
  label = "lb-test-pip"
  name = "formae-plugin-sdk-test-lb-pip-\(vars.testRunID)"
  location = "eastus"
  resourceGroupName = rg.res.name
  sku = pipSku
  publicIPAllocationMethod = "Static"
}

local lbSku = new loadbalancer.LoadBalancerSKU {
  name = "Standard"
  tier = "Regional"
}

forma {
  vars.stack

  vars.target

  rg
  pip

  new loadbalancer.LoadBalancer {
    label = "plugin-sdk-test-lb"
    name = "formae-plugin-sdk-test-lb-\(vars.testRunID)"
    location = "eastus"
    resourceGroupName = rg.res.name
    sku = lbSku
    frontendIPConfigurations = new Listing {
      new loadbalancer.FrontendIPConfiguration {
        name = "fe-public"
        publicIPAddressId = pip.res.id
      }
    }
    backendAddressPools = new Listing {
      new loadbalancer.BackendAddressPool { name = "be-pool" }
    }
    probes = new Listing {
      new loadbalancer.Probe {
        name = "tcp-80"
        protocol = "Tcp"
        port = 80
        intervalInSeconds = 5
        numberOfProbes = 2
      }
    }
    loadBalancingRules = new Listing {
      new loadbalancer.LoadBalancingRule {
        name = "rule-tcp-80"
        frontendIPConfigurationName = "fe-public"
        backendAddressPoolName = "be-pool"
        probeName = "tcp-80"
        protocol = "Tcp"
        frontendPort = 80
        backendPort = 80
        idleTimeoutInMinutes = 4
        disableOutboundSnat = false
        loadDistribution = "Default"
      }
    }
  }
}
