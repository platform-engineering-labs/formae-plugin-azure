amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@azure/azure.pkl"

import "@azure/resources/resourcegroup.pkl"
import "@azure/dashboard/grafana.pkl"
import "vars.pkl"

// Read the test run ID from environment variable set by the test harness
// This ensures consistent naming within a test run but unique names between runs

local rg = new resourcegroup.ResourceGroup {
  label = "grafana-test-rg"
  name = "formae-plugin-sdk-test-grafana-rg-\(vars.testRunID)"
  location = "eastus"
}

local grafanaSku = new grafana.GrafanaSKU {
  name = "Standard"
}

forma {
  vars.stack

  vars.target

  rg

  // Grafana name must be 2-23 chars, start with a letter, alphanumeric or hyphen
  new grafana.Grafana {
    label = "plugin-sdk-test-grafana"
    name = "grf\(vars.testRunID)"
    location = "eastus"
    resourceGroupName = rg.res.name
    sku = grafanaSku
    apiKey = "Disabled"
  }
}
