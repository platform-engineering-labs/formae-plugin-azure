amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@azure/azure.pkl"

import "@azure/resources/resourcegroup.pkl"
import "@azure/containerregistry/registry.pkl"
import "vars.pkl"

// Read the test run ID from environment variable set by the test harness
// This ensures consistent naming within a test run but unique names between runs

local rg = new resourcegroup.ResourceGroup {
  label = "acr-test-rg"
  name = "formae-plugin-sdk-test-acr-rg-\(vars.testRunID)"
  location = "eastus"
}

// Define sku as local to avoid SDK test patch logic targeting it
local registrySku = new registry.RegistrySKU {
  name = "Basic"
}

forma {
  vars.stack

  vars.target

  rg

  // ContainerRegistry name must be 5-50 chars, alphanumeric only (no hyphens)
  new registry.Registry {
    label = "plugin-sdk-test-acr"
    name = "fpsdtacr\(vars.testRunID)"
    location = "eastus"
    resourceGroupName = rg.res.name
    sku = registrySku
  }
}
