amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@azure/azure.pkl"

import "@azure/resources/resourcegroup.pkl"
import "@azure/managedidentity/userassignedidentity.pkl"
import "@azure/managedidentity/federatedidentitycredential.pkl"

local stackName = "plugin-sdk-test-fic-stack"
local testRunID = read("env:FORMAE_TEST_RUN_ID")

local rg = new resourcegroup.ResourceGroup {
  label = "fic-test-rg"
  name = "formae-plugin-sdk-test-fic-rg-\(testRunID)"
  location = "eastus"
}

local uai = new userassignedidentity.UserAssignedIdentity {
  label = "fic-test-uai"
  name = "formae-plugin-sdk-test-fic-uai-\(testRunID)"
  location = "eastus"
  resourceGroupName = rg.res.name
}

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK test for Azure FederatedIdentityCredential"
  }

  new formae.Target {
    label = "azure-target"
    config = new azure.Config {
      subscriptionId = "ddfe7ebf-ba62-442b-b915-24f71b04e63b"
    }
  }

  rg
  uai

  new federatedidentitycredential.FederatedIdentityCredential {
    label = "plugin-sdk-test-fic"
    name = "formae-plugin-sdk-test-fic-\(testRunID)"
    resourceGroupName = rg.res.name
    userAssignedIdentityName = uai.res.name
    issuer = "https://token.actions.githubusercontent.com"
    subject = "repo:platform-engineering-labs/formae:ref:refs/heads/main"
    audiences = new Listing { "api://AzureADTokenExchange" }
  }
}
