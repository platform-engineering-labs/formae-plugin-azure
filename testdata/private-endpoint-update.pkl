amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@azure/azure.pkl"

import "@azure/resources/resourcegroup.pkl"
import "@azure/resources/virtualnetwork.pkl"
import "@azure/resources/subnet.pkl"
import "@azure/storage/storageaccount.pkl"
import "@azure/network/privateendpoint.pkl"
import "vars.pkl"

local rg = new resourcegroup.ResourceGroup {
  label = "pe-test-rg"
  name = "formae-plugin-sdk-test-pe-rg-\(vars.testRunID)"
  location = "eastus"
}

local vnetAddressSpace = new virtualnetwork.AddressSpace {
  addressPrefixes = new Listing { "10.0.0.0/16" }
}

local vnet = new virtualnetwork.VirtualNetwork {
  label = "pe-test-vnet"
  name = "formae-plugin-sdk-test-pe-vnet-\(vars.testRunID)"
  location = "eastus"
  resourceGroupName = rg.res.name
  addressSpace = vnetAddressSpace
}

local snet = new subnet.Subnet {
  label = "pe-test-snet"
  name = "pe-snet"
  resourceGroupName = rg.res.name
  virtualNetworkName = vnet.res.name
  addressPrefix = "10.0.1.0/24"
}

local saSku = new storageaccount.StorageAccountSKU {
  name = "Standard_LRS"
}

local sa = new storageaccount.StorageAccount {
  label = "pe-test-sa"
  name = "fpsdtpe\(vars.testRunID)"
  location = "eastus"
  resourceGroupName = rg.res.name
  sku = saSku
  kind = "StorageV2"
}

forma {
  vars.stack

  vars.target

  rg
  vnet
  snet
  sa

  new privateendpoint.PrivateEndpoint {
    label = "plugin-sdk-test-pe"
    name = "formae-plugin-sdk-test-pe-\(vars.testRunID)"
    location = "eastus"
    resourceGroupName = rg.res.name
    subnetId = snet.res.id
    privateLinkServiceConnections = new Listing {
      new privateendpoint.PrivateLinkServiceConnection {
        name = "blob-conn"
        privateLinkServiceId = sa.res.id
        groupIds = new Listing { "blob" }
      }
    }
    // Update: add tags
    tags = new Listing {
      new azure.Tag { key = "Environment"; value = "updated" }
    }
  }
}
