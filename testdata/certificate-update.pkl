amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@azure/azure.pkl"

import "@azure/resources/resourcegroup.pkl"
import "@azure/keyvault/vault.pkl"
import "@azure/keyvault/certificate.pkl"
import "vars.pkl"

// NOTE: This conformance fixture uses the self-signed POLICY path (issuerName =
// "Self"), NOT the bring-your-own import path. The import path's `data` (base64
// PFX) and `password` are write-only — Azure never returns them on read, so the
// conformance harness (which compares desired vs read-back) would report false
// drift. The import path is covered by the plugin's marshaller round-trip unit
// test (TestKeyVaultCertificate_ImportRoundTrip) plus a manual live gate. This
// fixture still exercises the full certificate lifecycle against a real vault.

local azureTenantId = "35412a0c-6726-4fc9-98ef-6e91adcb8d0e"

local rg = new resourcegroup.ResourceGroup {
  label = "kv-cert-test-rg"
  name = "formae-plugin-sdk-test-kv-cert-rg-\(vars.testRunID)"
  location = "eastus"
}

local vaultSku = new vault.VaultSKU {
  family = "A"
  name = "standard"
}

local kv = new vault.Vault {
  label = "kv-cert-test-kv"
  name = "fpsdt-kv-crt-\(vars.testRunID)"
  location = "eastus"
  resourceGroupName = rg.res.name
  tenantId = azureTenantId
  sku = vaultSku
  enableSoftDelete = true
  softDeleteRetentionInDays = 7
  enableRbacAuthorization = true
}

forma {
  vars.stack

  vars.target

  rg
  kv

  new certificate.Certificate {
    label = "kv-cert-test-cert"
    name = "fpsdt-cert-\(vars.testRunID)"
    vaultUri = kv.res.vaultUri
    policy = new certificate.Policy {
      issuerName = "Self"
      subject = "CN=formae-test"
      keyType = "RSA"
      validityMonths = 12
    }
    // Update: add a tag (non-createOnly). The NativeID stays the same, proving
    // an in-place update rather than a replace.
    tags = new Listing {
      new azure.Tag { key = "Environment"; value = "updated" }
    }
  }
}
