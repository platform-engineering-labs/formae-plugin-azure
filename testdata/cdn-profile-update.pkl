amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@azure/azure.pkl"

import "@azure/resources/resourcegroup.pkl"
import "@azure/cdn/profile.pkl"
import "vars.pkl"

local rg = new resourcegroup.ResourceGroup {
  label = "cdn-test-rg"
  name = "formae-plugin-sdk-test-cdn-profile-rg-\(vars.testRunID)"
  location = "eastus"
}

forma {
  vars.stack

  vars.target

  rg

  new profile.Profile {
    label = "plugin-sdk-test-cdn-profile"
    name = "formae-sdk-afd-\(vars.testRunID)"
    location = "global"
    sku = new profile.SKU { name = "Standard_AzureFrontDoor" }
    resourceGroupName = rg.res.name
    // Update: adjust the origin response timeout (non-createOnly).
    originResponseTimeoutSeconds = 120
  }
}
