amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@azure/azure.pkl"

import "@azure/resources/resourcegroup.pkl"
import "@azure/eventhub/eventhubnamespace.pkl" as namespace

local stackName = "plugin-sdk-test-ehns-stack"
// Read the test run ID from environment variable set by the test harness
// This ensures consistent naming within a test run but unique names between runs
local testRunID = read("env:FORMAE_TEST_RUN_ID")

local rg = new resourcegroup.ResourceGroup {
  label = "ehns-test-rg"
  name = "formae-plugin-sdk-test-ehns-rg-\(testRunID)"
  location = "eastus"
}

// Define sku as local to avoid SDK test patch logic targeting it
local namespaceSku = new namespace.NamespaceSKU {
  name = "Standard"
  tier = "Standard"
}

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK test for Azure EventHub Namespace"
  }

  new formae.Target {
    label = "azure-target"
    config = new azure.Config {
      subscriptionId = "ddfe7ebf-ba62-442b-b915-24f71b04e63b"
    }
  }

  rg

  new namespace.Namespace {
    label = "plugin-sdk-test-ehns"
    name = "fpsdtehns\(testRunID)"
    location = "eastus"
    resourceGroupName = rg.res.name
    sku = namespaceSku
  }
}
