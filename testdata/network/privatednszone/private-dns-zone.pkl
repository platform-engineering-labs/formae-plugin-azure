amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@azure/azure.pkl"

import "@azure/resources/resourcegroup.pkl"
import "@azure/network/privatednszone.pkl"

local stackName = "plugin-sdk-test-pdz-stack"
local testRunID = read("env:FORMAE_TEST_RUN_ID")

local rg = new resourcegroup.ResourceGroup {
  label = "pdz-test-rg"
  name = "formae-plugin-sdk-test-pdz-rg-\(testRunID)"
  location = "eastus"
}

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK test for Azure PrivateDnsZone"
  }

  new formae.Target {
    label = "azure-target"
    config = new azure.Config {
      subscriptionId = "ddfe7ebf-ba62-442b-b915-24f71b04e63b"
    }
  }

  rg

  new privatednszone.PrivateDnsZone {
    label = "plugin-sdk-test-pdz"
    name = "formae-plugin-sdk-test-pdz-\(testRunID).internal"
    location = "global"
    resourceGroupName = rg.res.name
  }
}
