amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@azure/azure.pkl"

import "@azure/resources/resourcegroup.pkl"
import "@azure/network/routetable.pkl"

local stackName = "plugin-sdk-test-rt-stack"
local testRunID = read("env:FORMAE_TEST_RUN_ID")

local rg = new resourcegroup.ResourceGroup {
  label = "rt-test-rg"
  name = "formae-plugin-sdk-test-rt-rg-\(testRunID)"
  location = "eastus"
}

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK test for Azure RouteTable"
  }

  new formae.Target {
    label = "azure-target"
    config = new azure.Config {
      subscriptionId = "ddfe7ebf-ba62-442b-b915-24f71b04e63b"
    }
  }

  rg

  new routetable.RouteTable {
    label = "plugin-sdk-test-rt"
    // Replace: change name (createOnly field triggers delete+create)
    name = "formae-plugin-sdk-test-rt-replaced-\(testRunID)"
    location = "eastus"
    resourceGroupName = rg.res.name
    routes = new Listing {
      new routetable.Route {
        name = "to-appliance"
        addressPrefix = "10.1.0.0/16"
        nextHopType = "VirtualAppliance"
        nextHopIpAddress = "10.0.0.4"
      }
    }
  }
}
