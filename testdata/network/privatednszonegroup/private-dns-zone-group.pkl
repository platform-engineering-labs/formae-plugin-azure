amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@azure/azure.pkl"

import "@azure/resources/resourcegroup.pkl"
import "@azure/resources/virtualnetwork.pkl"
import "@azure/resources/subnet.pkl"
import "@azure/storage/storageaccount.pkl"
import "@azure/network/privateendpoint.pkl"
import "@azure/network/privatednszone.pkl"
import "@azure/network/privatednszonegroup.pkl"

local stackName = "plugin-sdk-test-pdzg-stack"
local testRunID = read("env:FORMAE_TEST_RUN_ID")

local rg = new resourcegroup.ResourceGroup {
  label = "pdzg-test-rg"
  name = "formae-plugin-sdk-test-pdzg-rg-\(testRunID)"
  location = "eastus"
}

local vnetAddressSpace = new virtualnetwork.AddressSpace {
  addressPrefixes = new Listing { "10.0.0.0/16" }
}

local vnet = new virtualnetwork.VirtualNetwork {
  label = "pdzg-test-vnet"
  name = "formae-plugin-sdk-test-pdzg-vnet-\(testRunID)"
  location = "eastus"
  resourceGroupName = rg.res.name
  addressSpace = vnetAddressSpace
}

local snet = new subnet.Subnet {
  label = "pdzg-test-snet"
  name = "pdzg-snet"
  resourceGroupName = rg.res.name
  virtualNetworkName = vnet.res.name
  addressPrefix = "10.0.1.0/24"
}

local saSku = new storageaccount.StorageAccountSKU {
  name = "Standard_LRS"
}

local sa = new storageaccount.StorageAccount {
  label = "pdzg-test-sa"
  name = "fpsdtpdzg\(testRunID)"
  location = "eastus"
  resourceGroupName = rg.res.name
  sku = saSku
  kind = "StorageV2"
}

local pe = new privateendpoint.PrivateEndpoint {
  label = "pdzg-test-pe"
  name = "formae-plugin-sdk-test-pdzg-pe-\(testRunID)"
  location = "eastus"
  resourceGroupName = rg.res.name
  subnetId = snet.res.id
  privateLinkServiceConnections = new Listing {
    new privateendpoint.PrivateLinkServiceConnection {
      name = "blob-conn"
      privateLinkServiceId = sa.res.id
      groupIds = new Listing { "blob" }
    }
  }
}

local zone = new privatednszone.PrivateDnsZone {
  label = "pdzg-test-zone"
  name = "privatelink.blob.core.windows.net"
  location = "global"
  resourceGroupName = rg.res.name
}

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK test for Azure PrivateDnsZoneGroup"
  }

  new formae.Target {
    label = "azure-target"
    config = new azure.Config {
      subscriptionId = "ddfe7ebf-ba62-442b-b915-24f71b04e63b"
    }
  }

  rg
  vnet
  snet
  sa
  pe
  zone

  new privatednszonegroup.PrivateDnsZoneGroup {
    label = "plugin-sdk-test-pdzg"
    name = "default"
    resourceGroupName = rg.res.name
    privateEndpointName = pe.res.name
    privateDnsZoneConfigs = new Listing {
      new privatednszonegroup.PrivateDnsZoneConfig {
        name = "blob-zone"
        privateDnsZoneId = zone.res.id
      }
    }
  }
}
