amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@azure/azure.pkl"

import "@azure/resources/resourcegroup.pkl"
import "@azure/keyvault/vault.pkl"
import "@azure/keyvault/secret.pkl"
import "vars.pkl"

local azureTenantId = "35412a0c-6726-4fc9-98ef-6e91adcb8d0e"

local rg = new resourcegroup.ResourceGroup {
  label = "kv-secret-test-rg"
  name = "formae-plugin-sdk-test-kv-secret-rg-\(vars.testRunID)"
  location = "eastus"
}

local vaultSku = new vault.VaultSKU {
  family = "A"
  name = "standard"
}

// Parent vault for the secret. RBAC-authorization mode: writing a secret is a
// data-plane operation, so the conformance principal must hold a data-plane role
// such as "Key Vault Secrets Officer" on this vault. Creating the vault via ARM
// does NOT grant it. See ../../../future-work.md section 1.
local kv = new vault.Vault {
  label = "kv-secret-test-kv"
  name = "fpsdt-kv-sec-\(vars.testRunID)"
  location = "eastus"
  resourceGroupName = rg.res.name
  tenantId = azureTenantId
  sku = vaultSku
  enableSoftDelete = true
  softDeleteRetentionInDays = 7
  enableRbacAuthorization = true
}

forma {
  vars.stack

  vars.target

  rg
  kv

  new secret.Secret {
    label = "kv-secret-test-secret"
    name = "fpsdt-secret-\(vars.testRunID)"
    vaultUri = kv.res.vaultUri
    value = formae.value("initial-secret-value").opaque.setOnce
    contentType = "text/plain"
  }
}
