amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@azure/azure.pkl"

import "@azure/resources/resourcegroup.pkl"
import "@azure/keyvault/vault.pkl"
import "vars.pkl"

// Read the test run ID from environment variable set by the test harness
// This ensures consistent naming within a test run but unique names between runs
local azureTenantId = "35412a0c-6726-4fc9-98ef-6e91adcb8d0e"

local rg = new resourcegroup.ResourceGroup {
  label = "kv-test-rg"
  name = "formae-plugin-sdk-test-kv-rg-\(vars.testRunID)"
  location = "eastus"
}

// Define sku as local to avoid SDK test patch logic targeting it
local vaultSku = new vault.VaultSKU {
  family = "A"
  name = "standard"
}

forma {
  vars.stack

  vars.target

  rg

  // KeyVault name must be 3-24 chars, start with letter, alphanumeric + hyphens
  // Soft delete enabled with minimum retention, purge protection off for test cleanup
  new vault.Vault {
    label = "plugin-sdk-test-kv"
    name = "fpsdt-kv-\(vars.testRunID)"
    location = "eastus"
    resourceGroupName = rg.res.name
    tenantId = azureTenantId
    sku = vaultSku
    enableSoftDelete = true
    softDeleteRetentionInDays = 7
  }
}
